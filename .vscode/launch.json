{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Prepare Dataset",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\prepare_dataset.py",
      "console": "integratedTerminal",
      "args": [
        "--overwrite"
      ]
    },
    {
      "name": "Train YOLOv8 Emotion Model",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\train_emotion_yolov8.py",
      "console": "integratedTerminal",
      "args": [
        "--epochs",
        "30",
        "--batch",
        "64",
        "--device",
        "0"
      ]
    },
    {
      "name": "Train timm Emotion Benchmark Model",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\train_emotion_timm.py",
      "console": "integratedTerminal",
      "args": [
        "--model-key",
        "resnet50",
        "--device",
        "cuda",
        "--overwrite"
      ]
    },
    {
      "name": "Run Focus Monitor",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\realtime_emotion_webcam.py",
      "console": "integratedTerminal",
      "args": [
        "--device",
        "0",
        "--window-width",
        "1280",
        "--window-height",
        "720"
      ]
    },
    {
      "name": "Run Driver Assistant GUI",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\driver_assistant_gui.py",
      "console": "integratedTerminal",
      "args": [
        "--device",
        "cuda"
      ]
    },
    {
      "name": "Run LLM Benchmark",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\llm_benchmark.py",
      "console": "integratedTerminal"
    },
    {
      "name": "Run Temperature Sweep",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\temperature_sweep.py",
      "console": "integratedTerminal",
      "args": [
        "--model",
        "openai/gpt-4o-mini"
      ]
    },
    {
      "name": "Score LLM Results",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\score_llm_results.py",
      "console": "integratedTerminal",
      "args": [
        "--input-csv",
        "${workspaceFolder}\\benchmark_results\\llm_benchmark\\manual_scores_template.csv"
      ]
    }
  ]
}
